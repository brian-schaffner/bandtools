        "message": "Title mappings saved successfully",
        "count": len(mappings)
    }


@app.get("/user/catalog")
async def get_user_catalog(request: Request, secret: str | None = Header(None, alias="X-Secret")):
    """Get the user's song catalog from their backup."""
    expected = SECRET
    if not expected or secret != expected:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    user_id = _get_user_id(request)
    user_data = _get_user_data(user_id)
    
    if not user_data.get("backups"):
        raise HTTPException(status_code=400, detail="No backup uploaded")
    
    latest_backup = user_data["backups"][-1]
    backup_path = Path(latest_backup["path"])
    
    try:
        # Extract catalog from backup using the same logic as backup_to_catalog.py
        import zipfile
        
        # Check if file exists and is a valid ZIP file
        if not backup_path.exists():
            raise HTTPException(status_code=404, detail="Backup file not found")
        
        if not backup_path.suffix.lower() in ['.zip', '.sbpbackup', '.bkp']:
            raise HTTPException(status_code=400, detail="Backup file is not a valid ZIP file")
        
        try:
            with zipfile.ZipFile(backup_path, 'r') as zf:
                # Check if dataFile.txt exists in the ZIP
                if "dataFile.txt" not in zf.namelist():
                    raise HTTPException(status_code=400, detail="dataFile.txt not found in backup")
                
                data_bytes = zf.read("dataFile.txt")
        except zipfile.BadZipFile:
            raise HTTPException(status_code=400, detail="Backup file is not a valid ZIP file")
        
        text = data_bytes.decode("utf-8-sig").strip()
        
        # Parse JSON content to extract song titles
        songs_items = []
        
        def collect_from_obj(obj):
            if isinstance(obj, dict):
                if isinstance(obj.get("songs"), list):
                    songs_items.extend(obj["songs"])
            elif isinstance(obj, list):
                songs_items.extend(obj)
        
        try:
            obj = json.loads(text)
            collect_from_obj(obj)
        except json.JSONDecodeError:
            # JSONL: parse each non-empty line
            for ln in (ln for ln in text.splitlines() if ln.strip()):
                try:
                    obj = json.loads(ln)
                    collect_from_obj(obj)
                except json.JSONDecodeError:
                    continue
        
        # Extract titles and songs with IDs
        titles = []
        songs = []
        for s in songs_items:
            if isinstance(s, dict):
                t = s.get("title") or s.get("name")
                if isinstance(t, str) and t.strip():
                    titles.append(t.strip())
                    # Only include active (non-deleted) songs
                    if not s.get("Deleted", False):
                        songs.append({
                            "id": s.get("Id"),
                            "name": t.strip()
                        })
            elif isinstance(s, str) and s.strip():
                titles.append(s.strip())
        
        return {
            "catalog": sorted(set(titles)),  # Remove duplicates and sort
            "songs": songs,  # Songs with IDs for the new mapping UI
            "count": len(set(titles)),
            "title_mapper": user_data.get("title_mapper", {})
        }
        
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Failed to extract catalog: {str(e)}")


@app.post("/user/verify-titles")
async def verify_user_titles(
    request: Request,
    titles: list[str],
    secret: str | None = Header(None, alias="X-Secret")
):
    """Verify titles against user's catalog and return suggestions."""
    expected = SECRET
    if not expected or secret != expected:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    user_id = _get_user_id(request)
    
    # Get user's catalog
    catalog_response = await get_user_catalog(request, secret)
    catalog = catalog_response["catalog"]
    
    # Get user's existing mappings
    user_dir = USER_DATA / user_id
    mapper_path = user_dir / "title_mapper.json"
    existing_mappings = {}
    if mapper_path.exists():
        with open(mapper_path, 'r', encoding='utf-8') as f:
            existing_mappings = json.load(f)
    
    # Normalize function (same as titles_verify.py)
    def normalize_key(s: str) -> str:
        import re
        s = s.strip()
        s = re.sub(r'\s+', ' ', s)
        s = re.sub(r"[\"'`']", "", s)
        s = s.replace('&', 'and')
        s = re.sub(r'\(feat[^\)]*\)', '', s, flags=re.I)
        s = re.sub(r'[^A-Za-z0-9 ]+', ' ', s)
        s = re.sub(r'\s+', ' ', s).strip()
        return s.casefold()
    
    # Build catalog index
    exact = {}
    canon_list = []
    for title in catalog:
        canon = title.strip()
        if not canon:
            continue
        nk = normalize_key(canon)
        exact[nk] = canon
        canon_list.append(canon)
    
    # Get suggestions for each title
    import difflib
    
    def best_suggestions(query: str, choices: list[str], n: int = 5):
        scores = []
        for c in choices:
            r = difflib.SequenceMatcher(a=normalize_key(query), b=normalize_key(c)).ratio()
            scores.append((c, r))
        scores.sort(key=lambda x: x[1], reverse=True)
        return scores[:n]
    
    # First apply title mappings (like titles_verify.py does)
    mapped_titles = []
    for title in titles:
        nk = normalize_key(title)
        if nk in existing_mappings:
            mapped = existing_mappings[nk]
            if mapped == "":
                continue  # dropped
            mapped_titles.append(mapped)
        else:
            mapped_titles.append(title)
    
    # Now verify the mapped titles against catalog
    results = []
    for title in mapped_titles:
        nk = normalize_key(title)
        
        # Check for exact match
        if nk in exact:
            results.append({
                "title": title,
                "status": "exact_match",
                "mapped_to": exact[nk],
                "suggestions": []
            })
            continue
        
        # Get suggestions
        suggestions = best_suggestions(title, canon_list, n=5)
        results.append({
            "title": title,
            "status": "needs_mapping",
            "mapped_to": None,
            "suggestions": [{"title": s[0], "score": s[1]} for s in suggestions]
        })
    
    return {
        "results": results,
        "total": len(titles),
        "needs_mapping": len([r for r in results if r["status"] == "needs_mapping"])
        }


@app.post("/user/reprocess-setlist")
async def reprocess_setlist(
    request: Request,
    secret: str | None = Header(None, alias="X-Secret")
):
    """Reprocess the most recent setlist with updated mappings."""
    print(f"DEBUG: reprocess-setlist called")
    expected = SECRET
    if not expected or secret != expected:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    user_id = _get_user_id(request)
    print(f"DEBUG: user_id = {user_id}")
    user_data = _get_user_data(user_id)
    print(f"DEBUG: user_data keys = {list(user_data.keys())}")
    
    # Get the most recent setlist
    if not user_data.get("setlists"):
        print("DEBUG: No setlists found")
        raise HTTPException(status_code=400, detail="No setlist found to reprocess")
    
    latest_setlist = user_data["setlists"][-1]
    print(f"DEBUG: latest_setlist = {latest_setlist}")
    setlist_path = Path(latest_setlist["path"])
    print(f"DEBUG: setlist_path = {setlist_path}")
    
    if not setlist_path.exists():
        print("DEBUG: Setlist file not found")
        raise HTTPException(status_code=400, detail="Setlist file not found")
    
    # Get the latest backup
    if not user_data.get("backups"):
        print("DEBUG: No backups found")
        raise HTTPException(status_code=400, detail="No backup found")
    
    latest_backup = user_data["backups"][-1]
    backup_path = latest_backup["path"]
    print(f"DEBUG: backup_path = {backup_path}")
    
    try:
        # Reprocess the setlist using the updated mappings
        print("DEBUG: Starting reprocessing...")
        env = _prepare_env()
        print("DEBUG: Calling _process_with_user_backup...")
        result = _process_with_user_backup(
            setlist_path, 
            latest_setlist["name"], 
            backup_path,
            env
        )
        print(f"DEBUG: Processing result - returncode: {result.returncode}")
        print(f"DEBUG: stdout: {result.stdout}")
        print(f"DEBUG: stderr: {result.stderr}")
        
        if result.returncode != 0:
            error_detail = f"Reprocessing failed (return code {result.returncode}): {result.stderr}"
            if result.stdout:
                error_detail += f"\nStdout: {result.stdout}"
            print(f"DEBUG: Error detail: {error_detail}")
            raise HTTPException(status_code=500, detail=error_detail)
        
        # Create new download file
        file_id = str(uuid.uuid4())
        download_path = USER_DATA / user_id / f"download_{datetime.now().strftime('%Y%m%d_%H%M%S')}_{latest_setlist['name']}.sbp"
        
        # Copy the generated file to user's download directory
        import shutil
        artifact_path = PACK / f"{latest_setlist['name']}.sbp"
        if artifact_path.exists():
            shutil.copy2(artifact_path, download_path)
            
            # Update user's download history
            download_entry = {
                "id": file_id,
                "filename": f"{latest_setlist['name']}.sbp",
                "original_filename": latest_setlist["filename"],
                "path": str(download_path),
                "created": datetime.now().isoformat(),
                "size": download_path.stat().st_size
            }
            
            if "downloads" not in user_data:
                user_data["downloads"] = []
            user_data["downloads"].append(download_entry)
            _save_user_data(user_id, user_data)
            
            # Generate download URL
            download_url = f"{request.url.scheme}://{request.url.netloc}/download_file/{file_id}"
            
            # Read processing results for detailed statistics
            try:
                # Read the verified titles to get counts
                verified_titles_path = PACK / "verified.txt"
                verified_titles = []
                if verified_titles_path.exists():
                    with open(verified_titles_path, 'r', encoding='utf-8') as f:
                        verified_titles = [line.strip() for line in f if line.strip()]
                
                # Read raw titles to get total count
                raw_titles_path = PACK / "raw_titles.txt"
                raw_titles = []
                if raw_titles_path.exists():
                    with open(raw_titles_path, 'r', encoding='utf-8') as f:
                        raw_titles = [line.strip() for line in f if line.strip()]
                
                # Read unfound titles from the unresolved report
                unfound_titles = []
                unresolved_report_path = PACK / "unresolved_report.txt"
                if unresolved_report_path.exists():
                    with open(unresolved_report_path, 'r', encoding='utf-8') as f:
                        report_content = f.read()
                        lines = report_content.split('\n')
                        for line in lines:
                            if line.startswith('UNRESOLVED:'):
                                title = line.replace('UNRESOLVED:', '').strip()
                                unfound_titles.append(title)
                
                return {
                    "ok": True,
                    "message": "Setlist reprocessed successfully",
                    "download_url": download_url,
                    "file_id": file_id,
                    "processing_results": {
                        "song_count": len(raw_titles),
                        "successful_mappings": len(verified_titles),
                        "unfound_titles": unfound_titles,
                        "all_titles": raw_titles
                    }
                }
            except Exception as e:
                print(f"[WARNING] Could not read processing statistics: {e}")
                return {
                    "ok": True,
                    "message": "Setlist reprocessed successfully",
                    "download_url": download_url,
                    "file_id": file_id
                }
        else:
            raise HTTPException(status_code=500, detail="Generated file not found")
            
    except Exception as e:
        import traceback
        error_detail = f"Reprocessing error: {str(e)}\nTraceback: {traceback.format_exc()}"
        raise HTTPException(status_code=500, detail=error_detail)


@app.get("/user/archive")
async def get_user_archive(request: Request, secret: str | None = Header(None, alias="X-Secret")):
    """Get comprehensive archive of all user files and processing history."""
    expected = SECRET
    if not expected or secret != expected:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    user_id = _get_user_id(request)
    user_data = _get_user_data(user_id)
    
    # Get all backups with enhanced info
    backups = user_data.get("backups", [])
    for backup in backups:
        backup["file_exists"] = Path(backup["path"]).exists()
        file_size = backup.get("metadata", {}).get("file_size", 0)
        backup["file_size_mb"] = round(file_size / (1024 * 1024), 2)
    
    # Sort backups by upload date (most recent first)
    backups.sort(key=lambda x: x.get("uploaded_at", ""), reverse=True)
    
    # Get all setlists with enhanced info
    setlists = user_data.get("setlists", [])
    for setlist in setlists:
        setlist["file_exists"] = Path(setlist["path"]).exists()
        file_size = setlist.get("metadata", {}).get("file_size", 0)
        setlist["file_size_mb"] = round(file_size / (1024 * 1024), 2)
    
    # Sort setlists by upload date (most recent first)
    setlists.sort(key=lambda x: x.get("uploaded_at", ""), reverse=True)
    
    # Get all downloads with enhanced info
    downloads = user_data.get("downloads", [])
    for download in downloads:
        download["file_exists"] = Path(download["path"]).exists()
        file_size = download.get("metadata", {}).get("file_size", 0)
        download["file_size_mb"] = round(file_size / (1024 * 1024), 2)
    
    # Sort downloads by upload date (most recent first)
    downloads.sort(key=lambda x: x.get("uploaded_at", ""), reverse=True)
    
    # Get title mappings
    title_mapper = user_data.get("title_mapper", {})
    
    # Create combined setlist/download groups
    combined_items = []
    for setlist in setlists:
        # Find related downloads for this setlist
        related_downloads = [d for d in downloads if d.get("metadata", {}).get("setlist_id") == setlist["id"]]
        
        # Create combined item
        combined_item = {
            "id": setlist["id"],
            "setlist": setlist,
            "downloads": related_downloads,
            "original_filename": setlist.get("metadata", {}).get("original_filename", setlist["filename"]),
            "uploaded_at": setlist["uploaded_at"],
            "file_size_mb": setlist["file_size_mb"],
            "file_exists": setlist["file_exists"],
            "has_downloads": len(related_downloads) > 0,
            "latest_download": related_downloads[0] if related_downloads else None
        }
        combined_items.append(combined_item)
    
    # Sort combined items by upload date (most recent first)
    combined_items.sort(key=lambda x: x.get("uploaded_at", ""), reverse=True)

    return {
        "user_id": user_id,
        "backups": backups,
        "combined_items": combined_items,  # New combined view
        "setlists": setlists,  # Keep original for compatibility
        "downloads": downloads,  # Keep original for compatibility
        "title_mapper": title_mapper,
        "summary": {
            "total_backups": len(backups),
            "total_setlists": len(setlists),
            "total_downloads": len(downloads),
            "total_combined_items": len(combined_items),
            "total_mappings": len(title_mapper),
            "latest_backup": backups[-1] if backups else None,
            "latest_setlist": setlists[-1] if setlists else None,
            "latest_download": downloads[-1] if downloads else None
        }
    }

@app.post("/user/reprocess-archive")
async def reprocess_archive_item(
    request: Request,
    item_type: str = Form(...),  # "setlist", "backup", or "download"
    item_id: str = Form(...),    # ID of the item to reprocess
    secret: str | None = Header(None, alias="X-Secret")
):
    """Reprocess an archived item (setlist, backup, or download)."""
    expected = SECRET
    if not expected or secret != expected:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    user_id = _get_user_id(request)
    user_data = _get_user_data(user_id)
    
    if item_type == "setlist":
        # Find the setlist by ID
        setlist = None
        for s in user_data.get("setlists", []):
            if s.get("id") == item_id:
                setlist = s
                break
        
        if not setlist:
            raise HTTPException(status_code=404, detail="Setlist not found")
        
        if not Path(setlist["path"]).exists():
            raise HTTPException(status_code=404, detail="Setlist file not found")
        
        # Reprocess the setlist
        try:
            print(f"DEBUG: Reprocessing setlist {item_id}")
            print(f"DEBUG: Setlist data: {setlist}")
            env = _prepare_env()
            # Use set_name from metadata, fallback to original_filename
            set_name = setlist.get("metadata", {}).get("set_name") or setlist.get("metadata", {}).get("original_filename") or "Set"
            print(f"DEBUG: Using set_name: {set_name}")
            print(f"DEBUG: Setlist path: {setlist['path']}")
            print(f"DEBUG: Backup path: {user_data['backups'][-1]['path']}")
            result = _process_with_user_backup(
                Path(setlist["path"]), 
                set_name, 
                user_data["backups"][-1]["path"],  # Use latest backup
                env
            )
            print(f"DEBUG: Processing result - returncode: {result.returncode}")
            print(f"DEBUG: stdout: {result.stdout}")
            print(f"DEBUG: stderr: {result.stderr}")
            
            if result.returncode != 0:
                raise HTTPException(status_code=500, detail=f"Reprocessing failed: {result.stderr}")
            
            # Create new download entry
            file_id = str(uuid.uuid4())
            download_path = USER_DATA / user_id / f"download_{datetime.now().strftime('%Y%m%d_%H%M%S')}_{set_name}.sbp"
            
            # Copy the generated file
            artifact_path = PACK / f"{set_name}.sbp"
            if artifact_path.exists():
                import shutil
                shutil.copy2(artifact_path, download_path)
                
                # Add to downloads
                download_entry = {
                    "id": file_id,
                    "filename": f"{set_name}.sbp",
                    "original_filename": setlist.get("metadata", {}).get("original_filename", setlist["filename"]),
                    "path": str(download_path),
                    "created": datetime.now().isoformat(),
                    "size": download_path.stat().st_size,
                    "reprocessed_from": item_id
                }
                
                if "downloads" not in user_data:
                    user_data["downloads"] = []
                user_data["downloads"].append(download_entry)
                _save_user_data(user_id, user_data)
                
                return {
                    "ok": True,
                    "message": f"Setlist '{set_name}' reprocessed successfully",
                    "download_id": file_id,
                    "download_path": str(download_path)
                }
            else:
                raise HTTPException(status_code=500, detail="Generated file not found")
                
        except Exception as e:
            raise HTTPException(status_code=500, detail=f"Reprocessing error: {str(e)}")
    
    elif item_type == "backup":
        raise HTTPException(status_code=400, detail="Backup reprocessing not implemented yet")
    
    elif item_type == "download":
        raise HTTPException(status_code=400, detail="Download reprocessing not implemented yet")
    
    else:
        raise HTTPException(status_code=400, detail="Invalid item type. Must be 'setlist', 'backup', or 'download'")

@app.delete("/user/archive/{item_type}/{item_id}")
async def delete_archive_item(
    item_type: str,
    item_id: str,
    request: Request,
    secret: str | None = Header(None, alias="X-Secret")
):
    """Delete an archived item."""
    expected = SECRET
    if not expected or secret != expected:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    user_id = _get_user_id(request)
    user_data = _get_user_data(user_id)
    
    # Find and remove the item
    if item_type == "backup":
        backups = user_data.get("backups", [])
        for i, backup in enumerate(backups):
            if backup.get("id") == item_id:
                # Delete the file
                try:
                    Path(backup["path"]).unlink()
                except FileNotFoundError:
                    pass  # File already deleted
                
                # Remove from list
                backups.pop(i)
                user_data["backups"] = backups
                _save_user_data(user_id, user_data)
                
                return {"ok": True, "message": "Backup deleted successfully"}
        
        raise HTTPException(status_code=404, detail="Backup not found")
    
    elif item_type == "setlist":
        setlists = user_data.get("setlists", [])
        for i, setlist in enumerate(setlists):
            if setlist.get("id") == item_id:
                # Delete the file
                try:
                    Path(setlist["path"]).unlink()
                except FileNotFoundError:
                    pass  # File already deleted
                
                # Remove from list
                setlists.pop(i)
                user_data["setlists"] = setlists
                _save_user_data(user_id, user_data)
                
                return {"ok": True, "message": "Setlist deleted successfully"}
        
        raise HTTPException(status_code=404, detail="Setlist not found")
    
    elif item_type == "download":
        downloads = user_data.get("downloads", [])
        for i, download in enumerate(downloads):
            if download.get("id") == item_id:
                # Delete the file
                try:
                    Path(download["path"]).unlink()
                except FileNotFoundError:
                    pass  # File already deleted
                
                # Remove from list
                downloads.pop(i)
                user_data["downloads"] = downloads
                _save_user_data(user_id, user_data)
                
                return {"ok": True, "message": "Download deleted successfully"}
        
        raise HTTPException(status_code=404, detail="Download not found")
    
    else:
        raise HTTPException(status_code=400, detail="Invalid item type")


# Google OAuth endpoints
@app.get("/auth/google")
async def google_auth_login():
    """Initiate Google OAuth login."""
    try:
        authorization_url, state = google_oauth.get_authorization_url()
        return RedirectResponse(url=authorization_url)
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Failed to initiate Google OAuth: {str(e)}")


@app.post("/auth/google/callback")
async def google_auth_callback_post(request: Request):
    """Handle Google OAuth callback (POST - for frontend API calls)."""
    try:
        body = await request.json()
        code = body.get('code')
        state = body.get('state')
        
        if not code:
            raise HTTPException(status_code=400, detail="Authorization code is required")
        
        # Exchange code for credentials
        credentials, user_info = google_oauth.exchange_code_for_token(code, state)
        
        # Create user ID from Google ID
        google_id = user_info.get('id')
        user_id = f"google_{google_id}"
        
        # Save credentials
        google_oauth.save_credentials(user_id, credentials)
        
        # Create or update user data
        user_data = _get_user_data(user_id)
        if not user_data:
            user_data = {
                "user_id": user_id,
                "google_id": google_id,
                "email": user_info.get('email'),
                "name": user_info.get('name'),
                "picture": user_info.get('picture'),
                "backups": [],
                "setlists": [],
                "downloads": [],
                "title_mappings": {},
                "created_at": datetime.now().isoformat(),
                "last_login": datetime.now().isoformat()
            }
        else:
            user_data["last_login"] = datetime.now().isoformat()
            user_data["email"] = user_info.get('email')
            user_data["name"] = user_info.get('name')
            user_data["picture"] = user_info.get('picture')
        
        _save_user_data(user_id, user_data)
        
        # Try to transfer guest data if user was previously a guest
        # This would need to be passed from the frontend, but for now we'll skip it
        # TODO: Implement guest data transfer when frontend provides guest session ID
        
        # Return success response for frontend
        return {
            "success": True,
            "user_id": user_id,
            "session_id": user_id,  # Use user_id as session_id for OAuth users
            "user_info": {
                "email": user_info.get('email'),
                "name": user_info.get('name'),
                "picture": user_info.get('picture')
            }
        }
        
    except Exception as e:
        raise HTTPException(status_code=400, detail=str(e))


@app.get("/auth/logout")
async def google_auth_logout(
    secret: str | None = Header(None, alias="X-Secret"),
    session_id: str | None = Header(None, alias="X-Session-ID")
):
    """Logout user and clear session."""
    if not secret or secret != SECRET:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    if not session_id:
        raise HTTPException(status_code=400, detail="Session ID required")
    
    try:
        # Clear user session data only (keep persistent data)
        if session_id in user_sessions:
            del user_sessions[session_id]
        
        # Just clear the session, don't delete user data
        # The user data should persist for when they log back in
        
        return {"success": True, "message": "Logged out successfully"}
        
    except Exception as e:
        print(f"Logout error: {e}")
        return {"success": True, "message": "Logged out successfully"}


@app.get("/auth/user")
async def get_auth_user(
    secret: str | None = Header(None, alias="X-Secret"),
    session_id: str | None = Header(None, alias="X-Session-ID")
):
    """Get authenticated user information."""
    if not secret or secret != SECRET:
        raise HTTPException(status_code=403, detail="Forbidden")
    
    if not session_id:
        raise HTTPException(status_code=400, detail="Session ID required")
    
    try:
        # Check if user is authenticated
        if not google_oauth.is_authenticated(session_id):
            raise HTTPException(status_code=401, detail="Not authenticated")
        
        # Load user data
        user_data = _get_user_data(session_id)
        if not user_data:
            raise HTTPException(status_code=404, detail="User not found")
        
        return {
            "user_id": user_data.get("user_id"),
            "google_id": user_data.get("google_id"),
            "email": user_data.get("email"),
            "name": user_data.get("name"),
            "picture": user_data.get("picture"),
            "created_at": user_data.get("created_at"),
            "last_login": user_data.get("last_login")
        }
        
    except HTTPException:
        raise
    except Exception as e:
        raise HTTPException(status_code=500, detail=f"Failed to get user info: {str(e)}")

