# from your repo root on the host (where bs.pdf and run.sh live)
docker run --rm -it \
  -p 8000:8000 \
  -v "$(pwd):/usr/local/src/setloader" \
  -w /usr/local/src/setloader \
  -e SECRET \
  -e SMTP_USER \
  -e SMTP_PASS \
  -e FROM_NAME \
  -e EMAIL_FALLBACK_TO \
  -e OPENAI_API_KEY \
  -e RUN_EXTRA_FLAGS \
  setloader:latest \
  python3 -m uvicorn server:app --host 0.0.0.0 --port 8000