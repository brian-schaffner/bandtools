#!/bin/sh
set -eu

./check-docker.sh

. ./vars.sh

IMG=${IMG:-my-uvicorn-app}
APPDIR=${APPDIR:-/usr/local/src/setloader}

# build image if missing
if ! docker image inspect "$IMG" >/dev/null 2>&1; then
#  echo "Building $IMG…"
  docker build -t "$IMG" .
fi

