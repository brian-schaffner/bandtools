# Copy to .env and fill in values (deploy script syncs to Fly secrets)
SECRET=change-me
NEXT_PUBLIC_API_SECRET=change-me
OPENAI_API_KEY=
GOOGLE_API_KEY=
# Gemini image generation (also accepts GEMINI_API_KEY)
GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
BRIDGE_SECRET=change-me

# Image providers (synced to Fly on deploy)
# GIG_IMAGE_PROVIDER=openai
# GIG_IMAGE_PROVIDER_SPLIT=1
# GIG_IMAGE_PROVIDER_A=openai
# GIG_IMAGE_PROVIDER_B=gemini
# GIG_IMAGE_PROVIDER_C=gemini
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Optional — set automatically per Fly app if omitted
# APP_URL=https://bandtools.fly.dev
# GOOGLE_REDIRECT_URI=https://bandtools.fly.dev/auth/google/callback
# BRIDGE_PUBLIC_URL=https://bandtools.fly.dev/flyers
