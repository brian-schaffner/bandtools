# Option C: set to 1 to try OpenAI hybrid after graphic composer (falls back on failure)
# OPTION_C_PREMIUM_HYBRID=0

# Copy to .env and fill in values
OPENAI_API_KEY=
# Image generation provider: openai (production default)
GIG_IMAGE_PROVIDER=openai
GIG_IMAGE_PROVIDER_SPLIT=0
OPENAI_IMAGE_USE_REFERENCE=1
OPENAI_IMAGE_INPUT_FIDELITY=high
# Single-pass compose: PIL places band photo on canvas, API adds typography (no post-overlay)
OPENAI_IMAGE_POST_COMPOSE=1
OPENAI_IMAGE_EDIT_MASK=1
# Experimental pipeline: typography_only sends blank canvas to API, PIL composites photo after
# OPENAI_IMAGE_PIPELINE=typography_only
# Legacy post-API photo paste — off by default (API output is final)
# OPENAI_IMAGE_POST_OVERLAY=0
# Legacy drift-based enforce overlay — off by default
# OPENAI_IMAGE_ENFORCE_PHOTO=0
# Per-tier quality overrides (defaults: conservative/medium=medium, creative=high)
# OPENAI_IMAGE_QUALITY_CREATIVE=high
# Defaults when split: A=openai, B=gemini, C=gemini
# GIG_IMAGE_PROVIDER_A=openai
# GIG_IMAGE_PROVIDER_B=gemini
# GIG_IMAGE_PROVIDER_C=gemini
# Gemini Nano Banana (requires GOOGLE_API_KEY or GEMINI_API_KEY)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_IMAGE_MODEL=gemini-3-pro-image
# GEMINI_IMAGE_ASPECT_RATIO=2:3
# GEMINI_IMAGE_SIZE=2K

# OpenAI image (when GIG_IMAGE_PROVIDER=openai)
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_SIZE=1024x1536
OPENAI_IMAGE_QUALITY=medium

GIG_CALENDAR_URL=https://www.lindseylane.com/dates/
GIG_CALENDAR_BAND=Lindsey Lane Band
GIG_CALENDAR_TIMEZONE=America/Kentucky/Louisville

# Calendar disk cache (default: cache/calendar.json, TTL 6 hours)
# GIG_CALENDAR_CACHE_PATH=/path/to/calendar.json
# GIG_CALENDAR_CACHE_TTL_SECONDS=21600
# GIG_CALENDAR_FETCH_TIMEOUT_SECONDS=45

# Optional LLM enrichment for gig research
# GIG_RESEARCH_USE_LLM=1
# GIG_RESEARCH_MODEL=gpt-4o-mini

# Band photos directory (default: bandphotos/)
# GIG_BANDPHOTOS_DIR=/path/to/bandphotos

# Fixed template renders (anti-slop) — all options A/B/C use structured_renderer
USE_FIXED_TEMPLATES=1
STRUCTURED_LAYOUT_OPTIONS=A,B,C
PHOTO_EFFECTS_BACKEND=pil

# Test mode: use fixtures/mock_gigs.json instead of live calendar
# GIG_FLYERS_TEST_MODE=1
# GIG_FLYERS_MOCK_PATH=/path/to/custom_mock_gigs.json

# AI reviewer (vision QA before showing options)
# AI_REVIEWER_ENABLED=1
# AI_REVIEWER_MODEL=gpt-4o-mini
# AI_REVIEWER_MAX_REMAKES=1

# Visual study AI predict (default: openai — band photo canvas + Hatch prompt)
# VISUAL_PREDICT_PROVIDER=openai

# iMessage bridge
BRIDGE_SECRET=change-me
BRIDGE_PORT=8010
IMESSAGE_RECIPIENT=
# Optional: path to Messages chat.db (defaults to ~/Library/Messages/chat.db)
MESSAGES_DB_PATH=

# Cursor webhook for iteration automation (set after saving Automation 2)
CURSOR_WEBHOOK_URL=
CURSOR_WEBHOOK_SECRET=

# Public URL for bridge (Tailscale Serve), e.g. https://machine.tailnet.ts.net/flyers
BRIDGE_PUBLIC_URL=

# Band Tools hub (defaults from BRIDGE_PUBLIC_URL without /flyers)
# BAND_TOOLS_URL=https://setlists.risk-tailor.ts.net

# Email delivery on approve (defaults to IMESSAGE_RECIPIENT)
EMAIL_RECIPIENT=

# Optional SMTP (if set, used instead of Mail.app)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_TLS=1
# EMAIL_FROM=
